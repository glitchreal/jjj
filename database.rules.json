{
  "rules": {
    ".read": false,
    ".write": false,
    "jobs": {
      ".read": true,
      ".indexOn": ["status", "createdAt", "updatedAt"],
      "$job": {
        ".write": "!newData.exists() || (newData.hasChildren(['placeId', 'jobId', 'status', 'createdAt', 'updatedAt']) && newData.child('placeId').isNumber() && newData.child('jobId').isString() && newData.child('status').isString() && (newData.child('status').val() == 'spawned' || newData.child('status').val() == 'claimed' || newData.child('status').val() == 'resolving' || newData.child('status').val() == 'killed' || newData.child('status').val() == 'failed' || newData.child('status').val() == 'expired' || newData.child('status').val() == 'missing') && newData.child('createdAt').isNumber() && newData.child('updatedAt').isNumber())"
      }
    },
    "activeServers": {
      ".read": true,
      ".indexOn": ["heartbeatAt"],
      "$job": {
        ".write": "!newData.exists() || (newData.hasChildren(['searcherId', 'claimedAt', 'heartbeatAt', 'placeId']) && newData.child('searcherId').isString() && newData.child('claimedAt').isNumber() && newData.child('heartbeatAt').isNumber() && newData.child('placeId').isNumber())"
      }
    },
    "recentServers": {
      ".read": true,
      "$searcher": {
        ".indexOn": ".value",
        "$job": {
          ".write": "!newData.exists() || newData.isNumber()"
        }
      }
    },
    "fleetRecent": {
      ".read": true,
      ".indexOn": ["checkedAt"],
      "$job": {
        ".write": "!newData.exists() || (newData.hasChildren(['checkedAt']) && newData.child('checkedAt').isNumber())"
      }
    },
    "candidatePool": {
      ".read": true,
      ".indexOn": ["discoveredAt"],
      "$job": {
        ".write": "!newData.exists() || (newData.hasChildren(['playing', 'discoveredAt']) && newData.child('playing').isNumber() && newData.child('discoveredAt').isNumber())"
      }
    },
    "candidatePoolMeta": {
      ".read": true,
      "refillLease": {
        ".write": "!newData.exists() || (newData.hasChildren(['searcherId', 'leaseId', 'acquiredAt', 'heartbeatAt', 'expiresAt']) && newData.child('searcherId').isString() && newData.child('leaseId').isString() && newData.child('acquiredAt').isNumber() && newData.child('heartbeatAt').isNumber() && newData.child('expiresAt').isNumber())"
      },
      "cleanupLease": {
        ".write": "!newData.exists() || (newData.hasChildren(['searcherId', 'leaseId', 'expiresAt']) && newData.child('searcherId').isString() && newData.child('leaseId').isString() && newData.child('expiresAt').isNumber())"
      },
      "cooldownUntil": {
        ".write": "!newData.exists() || newData.isNumber()"
      },
      "nextCursor": {
        ".write": "!newData.exists() || newData.isString()"
      },
      "lastRefillAt": {
        ".write": "!newData.exists() || newData.isNumber()"
      }
    },
    "scripts": {
      ".read": true,
      ".write": false
    }
  }
}
